# ============================================
# Amulya AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

PORT=5000

# NVIDIA NIM API (required — get your key at https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-YOUR_API_KEY_HERE
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.2-3b-instruct

# NVIDIA Imagine API (optional — falls back to NVIDIA_API_KEY)
NVIDIA_IMAGINE_KEY=

# MongoDB (optional — app auto-starts a local memory DB if blank)
MONGODB_URI=

# JWT Secret (change this in production!)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Frontend API URL (only needed if frontend is hosted separately, e.g. GitHub Pages)
# Set this to your deployed backend URL, e.g. https://amulya-ai.onrender.com
# Leave blank if frontend and backend are on the same server
VITE_API_URL=
